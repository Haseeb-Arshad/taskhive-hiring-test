DATABASE_URL=postgresql+asyncpg://taskhive:taskhive@localhost:5432/taskhive
NEXTAUTH_SECRET=your-secret-for-jwt-signing
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Orchestrator
TASKHIVE_API_BASE_URL=http://localhost:3000/api/v1
TASKHIVE_API_KEY=th_agent_0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# LLM Providers
OPENROUTER_API_KEY=sk-or-v1-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# Model tiers (format: provider/model-id)
# fast   = cheap/free for triage & clarification
# default = mid-tier for planning & execution
# strong  = best quality for complex tasks & review
# thinking = deep reasoning with chain-of-thought
FAST_MODEL=openrouter/arcee-ai/trinity-large-preview:free
DEFAULT_MODEL=openrouter/stepfun/step-3.5-flash:free
STRONG_MODEL=anthropic/claude-opus-4-5-20250514
THINKING_MODEL=moonshot/kimi-k2-thinking

# Deployment pipeline (MANDATORY — all tasks are deployed)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_ORG=your-github-org-or-username
GITHUB_REPO_PREFIX=taskhive-agent
GITHUB_BRANCH=main

# Vercel deployment (preferred: CLI via token, fallback: custom endpoint)
VERCEL_TOKEN=vcp_your_vercel_token_here
VERCEL_ORG_ID=team_your_vercel_org_id_here
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_DEPLOY_ENDPOINT=


MAX_CONCURRENT_TASKS=5
TASK_POLL_INTERVAL=30
SANDBOX_TIMEOUT=120
WORKSPACE_ROOT=/tmp/taskhive-workspaces
ALLOWED_COMMANDS=python,node,npm,npx,pip,git,ls,cat,head,tail,grep,find,mkdir,cp,mv,rm,touch,echo,curl,wget,tsc,eslint,flake8,pytest,make,sh,bash,cd,pwd,which,env,sort,uniq,wc,tr,cut,sed,awk,diff,patch,tar,gzip,unzip,ssh-keygen,openssl,jq,xargs
BLOCKED_PATTERNS=sudo,su ,chmod 777,rm -rf /,> /etc,> /dev

#uv sync; uv run uvicorn app.main:app --reload --port 8000
